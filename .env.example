# ─────────────────────────────────────────────────────────────────────────────
#  Autoharvester frontend env
#
#  Copy to `.env.local` for local dev, set in Vercel project settings for prod.
# ─────────────────────────────────────────────────────────────────────────────

# Public base URL of the Autoharvester backend API. Leave unset to keep the
# site running off the bundled demo JSON in `src/data/premium-listings.json`.
# When set, src/lib/api.ts will call /api/insights/* on this host.
#
# Local:    http://localhost:3001
# Staging:  https://autoharvester-backend-staging.up.railway.app
# Prod:     https://api.autoharvester.com.au
NEXT_PUBLIC_API_BASE=
